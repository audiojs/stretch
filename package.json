{
  "name": "@audio/stretch",
  "version": "2.0.0",
  "type": "module",
  "types": "index.d.ts",
  "description": "Time stretching — umbrella for @audio/stretch-* atoms (WSOLA, phase vocoder variants, PaulStretch, PSOLA, SMS)",
  "sideEffects": false,
  "main": "index.js",
  "exports": {
    ".": "./index.js",
    "./package.json": "./package.json"
  },
  "files": [
    "index.js",
    "index.d.ts",
    "LICENSE"
  ],
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "test": "node test.js",
    "test:browser": "node test/browser.js",
    "test:all": "npm test --workspaces --if-present && npm test && npm run test:browser",
    "publish:all": "npm publish --workspaces && npm publish"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/audiojs/time-stretch.git"
  },
  "keywords": [
    "time-stretch",
    "time-stretching",
    "wsola",
    "phase-vocoder",
    "phase-locking",
    "pghi",
    "transient",
    "hpss",
    "hybrid",
    "paulstretch",
    "psola",
    "sms",
    "sinusoidal",
    "tempo",
    "audio",
    "dsp",
    "signal-processing"
  ],
  "author": "Dmitry Iv. <dfcreative@gmail.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/audiojs/time-stretch/issues"
  },
  "homepage": "https://github.com/audiojs/time-stretch#readme",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@audio/stretch-core": "^1.0.0",
    "@audio/stretch-hybrid": "^1.0.0",
    "@audio/stretch-paulstretch": "^1.0.0",
    "@audio/stretch-pghi": "^1.0.0",
    "@audio/stretch-psola": "^1.0.0",
    "@audio/stretch-pvoc": "^1.0.0",
    "@audio/stretch-pvoc-lock": "^1.0.0",
    "@audio/stretch-sms": "^1.0.0",
    "@audio/stretch-transient": "^1.0.0",
    "@audio/stretch-wsola": "^1.0.0"
  },
  "devDependencies": {
    "audio-lena": "^3.0.0",
    "playwright": "^1.59.1",
    "tst": "^9.4.0",
    "wavefont": "^3.5.0"
  }
}
