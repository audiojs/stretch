{
  "name": "@audio/stretch-pghi",
  "version": "1.2.1",
  "description": "Phase Gradient Heap Integration vocoder (Průša & Holighaus \"Phase Vocoder Done Right\") — no peak picking, no transient heuristics",
  "type": "module",
  "sideEffects": false,
  "main": "pghi.js",
  "types": "pghi.d.ts",
  "exports": {
    ".": "./pghi.js",
    "./audio": {
      "types": "./audio.d.ts",
      "default": "./audio.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "pghi.js",
    "pghi.d.ts",
    "README.md",
    "LICENSE",
    "util.js",
    "audio.js",
    "audio.d.ts"
  ],
  "dependencies": {
    "fourier-transform": "^2.3.0"
  },
  "keywords": [
    "audio",
    "dsp",
    "time-stretch",
    "phase-vocoder",
    "pghi",
    "rtpghi",
    "phase-gradient",
    "stft"
  ],
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "author": "Dmitry Iv. <dfcreative@gmail.com>",
  "homepage": "https://github.com/audiojs/stretch/tree/main/packages/stretch-pghi",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/audiojs/stretch.git",
    "directory": "packages/stretch-pghi"
  },
  "bugs": "https://github.com/audiojs/stretch/issues",
  "engines": {
    "node": ">=18"
  },
  "audio": "./audio.js",
  "funding": "https://github.com/sponsors/audiojs"
}
