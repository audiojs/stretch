{
  "name": "@audio/stretch-psola",
  "version": "1.2.0",
  "description": "Pitch-Synchronous Overlap-Add — time-domain stretch for speech and monophonic instruments",
  "type": "module",
  "sideEffects": false,
  "main": "psola.js",
  "types": "psola.d.ts",
  "exports": {
    ".": "./psola.js",
    "./audio": {
      "types": "./audio.d.ts",
      "default": "./audio.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "psola.js",
    "psola.d.ts",
    "README.md",
    "LICENSE",
    "util.js",
    "audio.js",
    "audio.d.ts"
  ],
  "dependencies": {
    "@audio/stretch-wsola": "^1.0.0"
  },
  "keywords": [
