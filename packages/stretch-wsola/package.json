{
  "name": "@audio/stretch-wsola",
  "version": "1.2.1",
  "description": "WSOLA time stretching — time-domain, low CPU, great for speech",
  "type": "module",
  "sideEffects": false,
  "main": "wsola.js",
  "types": "wsola.d.ts",
  "exports": {
    ".": "./wsola.js",
    "./audio": {
      "types": "./audio.d.ts",
      "default": "./audio.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "wsola.js",
    "wsola.d.ts",
    "README.md",
    "LICENSE",
    "util.js",
    "audio.js",
    "audio.d.ts"
  ],
  "keywords": [
    "audio",
    "dsp",
    "time-stretch",
    "wsola",
    "tempo",
    "speech"
  ],
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "author": "Dmitry Iv. <dfcreative@gmail.com>",
  "homepage": "https://github.com/audiojs/stretch/tree/main/packages/stretch-wsola",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/audiojs/stretch.git",
    "directory": "packages/stretch-wsola"
  },
  "bugs": "https://github.com/audiojs/stretch/issues",
  "engines": {
    "node": ">=18"
  },
  "audio": "./audio.js",
  "funding": "https://github.com/sponsors/audiojs"
}
